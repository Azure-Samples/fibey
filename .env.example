# Microsoft Foundry
# For local dev, set these manually. For hosted agents, FOUNDRY_PROJECT_ENDPOINT
# is auto-injected by the Foundry platform.
FOUNDRY_PROJECT_ENDPOINT=
FOUNDRY_MODEL=gpt-4.1-mini

# Agent Mode: "local" (run in-process), "hosted" (proxy to Foundry hosted agent), or "containerapp" (proxy to self-hosted agent service)
AGENT_MODE=local

# Hosted mode settings (when AGENT_MODE=hosted)
HOSTED_AGENT_NAME=fibey-agent

# Container App mode settings (when AGENT_MODE=containerapp)
# URL to your deployed agent service container app
CONTAINERAPP_AGENT_URL=https://your-agent-service.azurecontainerapps.io

# Foundry Toolbox MCP
# Set this to the toolbox MCP endpoint URL WITHOUT api-version (automatically appended).
# Example: https://<account>.services.ai.azure.com/api/projects/<project>/toolboxes/<name>/mcp
# Note: The agent code automatically adds ?api-version=v1
TOOLBOX_MCP_URL=

# Knowledge Base (Azure AI Search — semantic search)
# Used for direct KB queries when the toolbox azure_ai_search tool is unavailable.
AZURE_SEARCH_ENDPOINT=https://<search-service>.search.windows.net
AZURE_SEARCH_INDEX=foundry-iq-docs-index
AZURE_SEARCH_API_KEY=

# Gateway
GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=8080
