# Foundry-hosted agent image: built remotely (remoteBuild) for the
# `fibey-agent` service in azure.yaml. Installs deps from requirements.txt
# and runs the hosted agent entrypoint (src/fibey/agent/hosted.py).
FROM mirror.gcr.io/library/python:3.12-slim

WORKDIR /app

COPY . user_agent/
WORKDIR /app/user_agent

RUN if [ -f requirements.txt ]; then \
        pip install --no-cache-dir -r requirements.txt; \
    else \
        echo "No requirements.txt found"; \
    fi

EXPOSE 8088

CMD ["python", "src/fibey/agent/hosted.py"]
